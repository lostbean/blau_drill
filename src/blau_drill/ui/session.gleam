/// Run one wire command through the printer FSM and keep ONLY the resulting
/// state (the Session nests the state; the app runs the actual writes from the
/// Plan). Pure.
fn run_wire(
  p: printer.PrinterState,
  cmd: printer.Command,
) -> printer.PrinterState {
  let printer.Step(state: next, ..) = printer.command(p, cmd)
  next
}

/// Drive the wire to a faulted state via `serial_lost`, keeping only the state.
fn faulted_wire(p: printer.PrinterState) -> printer.PrinterState {
  let printer.Step(state: next, ..) = printer.serial_lost(p, "serial loss")
  next
}

/// Build a `Faulted` session that carries the current job (rolling off an
/// active state) and faults the wire.
fn fault_with(j: job.Job, s: Session) -> Session {
  Faulted(job: model.HaveJob(j), printer: faulted_wire(wire_of(s)))
}

/// The nested wire of any Session.
fn wire_of(s: Session) -> printer.PrinterState {
  case s {
    Loading(printer: p, ..) -> p
    Aligning(printer: p, ..) -> p
    Rehearsing(printer: p, ..) -> p
    Drilling(printer: p, ..) -> p
    Completed(printer: p, ..) -> p
    Faulted(printer: p, ..) -> p
  }
}

/// Apply a non-streaming `job` move and pair it with a (usually empty) Plan,
/// rebuilding the Session via `rebuild`. The wire is unchanged for these moves.
fn step_job(
  j: job.Job,
  ev: job.Event,
  p: printer.PrinterState,
  plan: Plan,
  rebuild: fn(job.Job, printer.PrinterState) -> Session,
) -> Result(#(Session, Plan), Rejected) {
  case job.transition(j, ev) {
    Ok(j2) -> Ok(#(rebuild(j2, p), plan))
    Error(e) -> Error(JobRefused(e))
  }
}

/// Rebuild an `Aligning` session from a job + wire (the alignment stages stay in
/// `Aligning`).
fn aligning_of(j: job.Job, p: printer.PrinterState) -> Session {
  Aligning(job: j, printer: p)
}

/// The board a job carries, wrapped for `Loading`.
fn board_of_job(j: job.Job) -> model.BoardOpt {
  // The job carries a domain `BoardModel`, not a canvas `model.Board`; the
  // caller (app) holds the canvas board. For a de-energize that returns to
  // Loading, the Session keeps no canvas board here (the app re-supplies it via
  // its own `model.board`); we return `NoBoard` so the Session stays pure of the
  // board_of conversion. The lifecycle screen is `Load` either way.
  let _ = j
  model.NoBoard
}
